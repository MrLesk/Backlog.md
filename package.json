{
  "name": "backlog.md",
  "version": "1.48.0",
  "type": "module",
  "module": "src/cli.ts",
  "files": [
    "scripts/*.cjs",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "backlog": "scripts/cli.cjs"
  },
  "optionalDependencies": {
    "backlog.md-darwin-arm64": "*",
    "backlog.md-darwin-x64": "*",
    "backlog.md-linux-arm64": "*",
    "backlog.md-linux-x64": "*",
    "backlog.md-windows-arm64": "*",
    "backlog.md-windows-x64": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@clack/core": "1.4.3",
    "@clack/prompts": "1.7.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@types/bun": "1.3.14",
    "@types/jsdom": "28.0.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/react-router-dom": "5.3.3",
    "@uiw/react-markdown-preview": "5.2.1",
    "@uiw/react-md-editor": "4.1.1",
    "bun-plugin-tailwind": "0.1.2",
    "commander": "15.0.0",
    "fuse.js": "7.4.2",
    "gray-matter": "4.0.3",
    "husky": "9.1.7",
    "install": "0.13.0",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.8",
    "mermaid": "11.16.0",
    "neo-neo-bblessed": "1.0.9",
    "picocolors": "1.1.1",
    "proper-lockfile": "4.1.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1",
    "react-tooltip": "6.0.8",
    "tailwindcss": "4.3.2",
    "typescript": "7.0.2"
  },
  "scripts": {
    "test": "bun test",
    "format": "biome format --write .",
    "lint": "biome lint --write .",
    "check": "biome check .",
    "check:types": "bunx tsc --noEmit",
    "prepare": "husky",
    "build": "bun scripts/build.ts",
    "cli": "bun src/cli.ts",
    "mcp": "bun src/cli.ts mcp start",
    "update-nix": "bunx bun2nix@2.1.1 -o bun.nix"
  },
  "lint-staged": {
    "package.json": [
      "biome check --write --files-ignore-unknown=true"
    ],
    "*.json": [
      "biome check --write --files-ignore-unknown=true"
    ],
    "src/**/*.{ts,js}": [
      "biome check --write --files-ignore-unknown=true"
    ]
  },
  "author": "Alex Gavrilescu (https://github.com/MrLesk)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MrLesk/Backlog.md.git"
  },
  "bugs": {
    "url": "https://github.com/MrLesk/Backlog.md/issues"
  },
  "homepage": "https://backlog.md",
  "keywords": [
    "cli",
    "markdown",
    "kanban",
    "task",
    "project-management",
    "backlog",
    "agents"
  ],
  "license": "MIT",
  "trustedDependencies": [
    "@biomejs/biome",
    "bun",
    "node-pty"
