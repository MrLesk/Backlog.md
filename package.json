{
	"name": "backlog.md",
	"version": "0.0.0",
	"type": "module",
	"bin": {
		"backlog": "cli/index.js"
	},
	"dependencies": {
		"blessed": "npm:neo-neo-bblessed@1.0.3"
	},
	"optionalDependencies": {
		"backlog.md-darwin-arm64": "*",
		"backlog.md-darwin-x64": "*",
		"backlog.md-linux-arm64": "*",
		"backlog.md-linux-x64": "*",
		"backlog.md-windows-x64": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "2.0.5",
		"@dnd-kit/core": "6.3.1",
		"@dnd-kit/sortable": "10.0.0",
		"@dnd-kit/utilities": "3.2.2",
		"@radix-ui/react-dialog": "1.1.14",
		"@radix-ui/react-select": "2.2.5",
		"@radix-ui/react-slot": "1.2.3",
		"@radix-ui/react-tabs": "1.1.12",
		"@types/bun": "1.2.17",
		"@types/prompts": "2.4.9",
		"@types/react": "18.3.23",
		"@types/react-dom": "18.3.7",
		"@vitejs/plugin-react": "4.6.0",
		"autoprefixer": "10.4.21",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"commander": "14.0.0",
		"gray-matter": "4.0.3",
		"husky": "9.1.7",
		"lint-staged": "16.1.2",
		"lucide-react": "0.523.0",
		"prompts": "2.4.2",
		"react": "18.3.0",
		"react-dom": "18.3.0",
		"react-markdown": "10.1.0",
		"tailwind-merge": "3.3.1",
		"tailwindcss": "4.1.10",
		"typescript": "5.8.3",
		"vite": "7.0.0",
		"zod": "3.25.67"
	},
	"scripts": {
		"test": "bun test",
		"test:windows": "bun test --timeout 10000",
		"typecheck": "bunx tsc --noEmit",
		"format": "biome format --write .",
		"lint": "biome lint --write .",
		"check": "biome check . && bun run typecheck",
		"prepare": "husky",
		"build:cli": "bun build --compile --minify --outfile=backlog src/cli.ts",
		"build": "bun run build:cli",
		"cli": "bun src/cli.ts"
	},
	"lint-staged": {
		"*.{ts,js,json}": [
			"biome check --write --files-ignore-unknown=true"
		],
		"src/**/*.{ts,js}": [
			"biome check --write --files-ignore-unknown=true"
		]
	},
	"author": "Alex Gavrilescu (https://github.com/MrLesk)",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/MrLesk/Backlog.md.git"
	},
	"bugs": {
		"url": "https://github.com/MrLesk/Backlog.md/issues"
	},
	"homepage": "https://backlog.md",
	"keywords": [
		"cli",
		"markdown",
		"kanban",
		"task",
		"project-management",
		"backlog",
		"agents"
	],
	"license": "MIT",
	"trustedDependencies": [
		"@biomejs/biome",
		"node-pty"
	]
}
