{
	"name": "backlog.md",
	"version": "0.0.0",
	"type": "module",
	"bin": {
		"backlog": "cli/index.js"
	},
	"dependencies": {
		"blessed": "npm:neo-neo-bblessed@1.0.3",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"tailwindcss": "^4.0.6"
	},
	"optionalDependencies": {
		"backlog.md-darwin-arm64": "*",
		"backlog.md-darwin-x64": "*",
		"backlog.md-linux-arm64": "*",
		"backlog.md-linux-x64": "*",
		"backlog.md-windows-x64": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "2.0.5",
		"@tailwindcss/vite": "^4.1.10",
		"@types/bun": "1.2.17",
		"@types/prompts": "2.4.9",
		"@types/react": "^19.1.8",
		"@types/react-dom": "^19.1.6",
		"@vitejs/plugin-react": "^4.6.0",
		"bun-plugin-tailwind": "^0.0.14",
		"commander": "14.0.0",
		"gray-matter": "4.0.3",
		"husky": "9.1.7",
		"lint-staged": "16.1.2",
		"prompts": "2.4.2",
		"typescript": "5.8.3",
		"vite": "^7.0.0",
		"zod": "3.25.67"
	},
	"scripts": {
		"test": "bun test",
		"test:windows": "bun test --timeout 10000",
		"typecheck": "bunx tsc --noEmit",
		"format": "biome format --write .",
		"lint": "biome lint --write .",
		"check": "biome check . && bun run typecheck",
		"prepare": "husky",
		"build": "bun run build:web && bun run build:cli",
		"build:web": "bun vite build --config vite.config.ts",
		"build:cli": "bun build ./src/cli.ts --compile --outfile backlog --minify --sourcemap",
		"dev:web": "bun --hot src/web-ui/index.ts",
		"cli": "bun src/cli.ts"
	},
	"lint-staged": {
		"*.{ts,js,json}": [
			"biome check --write --files-ignore-unknown=true"
		],
		"src/**/*.{ts,js}": [
			"biome check --write --files-ignore-unknown=true"
		]
	},
	"author": "Alex Gavrilescu (https://github.com/MrLesk)",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/MrLesk/Backlog.md.git"
	},
	"bugs": {
		"url": "https://github.com/MrLesk/Backlog.md/issues"
	},
	"homepage": "https://backlog.md",
	"keywords": [
		"cli",
		"markdown",
		"kanban",
		"task",
		"project-management",
		"backlog",
		"agents"
	],
	"license": "MIT",
	"trustedDependencies": [
		"@biomejs/biome",
		"node-pty"
	]
}
